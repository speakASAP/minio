# MinIO Microservice - keys only; set values in .env (never commit .env)
# Used by systemd unit on alfares, and by Docker blue/green deploy on statex.

NODE_ENV=
DOMAIN=
SERVICE_NAME=minio-microservice

# MinIO API and Console ports (Docker deploy)
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# MinIO credentials (required for Docker; set strong values).
# If using shell scripts that source .env, quote values containing ) $ " ` etc.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
RECORDS_BUCKET=records

# Logging (central logging-microservice)
# Docker: http://logging-microservice:3367  Production: https://logging.alfares.cz
LOGGING_SERVICE_URL=

# Network (Docker blue/green)
NGINX_NETWORK_NAME=nginx-network

# Optional: custom endpoint (e.g. for portal on prod pointing to dev MinIO)
# MINIO_ENDPOINT_URL=
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=

# Unified payments configuration
PAYMENT_APPLICATION_ID=
PAYMENT_SERVICE_URL=
PAYMENT_API_KEY=
PAYMENT_WEBHOOK_API_KEY=
PAYMENT_CALLBACK_URL=
PAYMENT_SUCCESS_URL=
PAYMENT_CANCEL_URL=
